{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WILQ Codex Skill Eval Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skill": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "const": "pl-PL"
    },
    "polish_diacritics_present": {
      "type": "boolean"
    },
    "api_used": {
      "type": "boolean"
    },
    "api_base": {
      "type": "string"
    },
    "allowed_endpoint_violation": {
      "type": "boolean"
    },
    "source_connectors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "opportunity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knowledge_card_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expert_rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label_pl": {
            "type": "string"
          },
          "source_connectors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "blocked_reason": {
            "type": ["string", "null"]
          }
        },
        "required": [
          "label_pl",
          "source_connectors",
          "evidence_ids",
          "confidence",
          "blocked_reason"
        ]
      }
    },
    "action_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label_pl": {
            "type": "string"
          },
          "action_id": {
            "type": ["string", "null"]
          },
          "validation_state": {
            "type": "string",
            "enum": ["none", "missing", "pending_validation", "validated", "failed", "blocked"]
          },
          "blocked_reason": {
            "type": ["string", "null"]
          }
        },
        "required": [
          "label_pl",
          "action_id",
          "validation_state",
          "blocked_reason"
        ]
      }
    },
    "blocked": {
      "type": "boolean"
    },
    "blocked_reason": {
      "type": ["string", "null"]
    },
    "safety_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operator_next_step": {
      "type": "string"
    },
    "operator_usefulness_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "eval_rubric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "objective_pl": {
          "type": "string"
        },
        "evaluator_type": {
          "type": "string",
          "enum": ["deterministic_pass_fail"]
        },
        "hard_gates": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "evidence_requirement_handled": {
              "type": "boolean"
            },
            "source_connector_requirement_handled": {
              "type": "boolean"
            },
            "blocked_claims_handled": {
              "type": "boolean"
            },
            "action_validation_handled": {
              "type": "boolean"
            },
            "freshness_or_blocker_handled": {
              "type": "boolean"
            },
            "workflow_specificity_handled": {
              "type": "boolean"
            }
          },
          "required": [
            "evidence_requirement_handled",
            "source_connector_requirement_handled",
            "blocked_claims_handled",
            "action_validation_handled",
            "freshness_or_blocker_handled",
            "workflow_specificity_handled"
          ]
        },
        "score_reason_pl": {
          "type": "string"
        }
      },
      "required": [
        "objective_pl",
        "evaluator_type",
        "hard_gates",
        "score_reason_pl"
      ]
    },
    "failure_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "missing_evidence_handling",
          "missing_source_connector_handling",
          "unsafe_claim_handling",
          "invalid_action_validation",
          "stale_without_refresh_or_blocker",
          "generic_workflow_output",
          "wrong_workflow_surface",
          "non_polish_operator_output",
          "secret_or_raw_payload_exposure"
        ]
      }
    },
    "decision_quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actionable_decision": {
          "type": "boolean"
        },
        "safe_next_step_present": {
          "type": "boolean"
        },
        "blocked_claims_handled": {
          "type": "boolean"
        },
        "workflow_specific_interpretation": {
          "type": "boolean"
        },
        "evidence_backed_reasoning": {
          "type": "boolean"
        },
        "first_action_clear": {
          "type": "boolean"
        },
        "why_this_first_clear": {
          "type": "boolean"
        },
        "notes_pl": {
          "type": "string"
        }
      },
      "required": [
        "actionable_decision",
        "safe_next_step_present",
        "blocked_claims_handled",
        "workflow_specific_interpretation",
        "evidence_backed_reasoning",
        "first_action_clear",
        "why_this_first_clear",
        "notes_pl"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "skill",
    "language",
    "polish_diacritics_present",
    "api_used",
    "api_base",
    "allowed_endpoint_violation",
    "source_connectors",
    "evidence_ids",
    "opportunity_ids",
    "knowledge_card_ids",
    "expert_rule_ids",
    "recommendations",
    "action_candidates",
    "blocked",
    "blocked_reason",
    "safety_findings",
    "operator_next_step",
    "operator_usefulness_score",
    "eval_rubric",
    "failure_tags",
    "decision_quality",
    "notes"
  ]
}
