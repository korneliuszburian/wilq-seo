{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start.py\"",
            "timeout": 20,
            "statusMessage": "Checking WILQ API status"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_log.py\"",
            "timeout": 20,
            "statusMessage": "Recording WILQ Codex run summary"
          }
        ]
      }
    ]
  }
}

